{
    "name": "psc-acme/wrapper-auth",
    "description": "Package wrapper-auth for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\WrapperAuth\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/string": "^7.0",
        "league/csv": "^9.0",
        "webmozart/assert": "^1.0",
        "symfony/serializer": "^7.0",
        "psc-acme/adapter-auth": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}